{
  "manifest_version": 3,
  "name": "WatchTogether",
  "version": "0.1.0",
  "description": "Watch parties for couples and friend groups",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.youtube.com/*",
    "https://www.amazon.com/*",
    "https://www.primevideo.com/*",
    "https://www.hotstar.com/*",
    "https://www.sonyliv.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.netflix.com/*",
        "https://www.youtube.com/*",
        "https://www.amazon.com/*",
        "https://www.primevideo.com/*",
        "https://www.hotstar.com/*",
        "https://www.sonyliv.com/*"
      ],
      "js": ["libsodium.js", "purify.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["libsodium.js", "purify.min.js", "content.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
